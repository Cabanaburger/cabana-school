<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Migração de cursos — Cabana School (uso único)</title>
<style>
  body{ font-family:-apple-system,'Avenir Next',sans-serif; background:#FBF3D9; color:#1E1A14; max-width:760px; margin:40px auto; padding:0 24px 60px; }
  h1{ font-size:22px; }
  h2{ font-size:16px; margin-top:34px; }
  p{ line-height:1.6; color:#574E3F; font-size:14px; }
  .step{ background:#FFFDF7; border:1px solid rgba(30,26,20,0.1); border-radius:16px; padding:20px 22px; margin-top:14px; }
  .curso-row{ display:flex; align-items:center; justify-content:space-between; gap:14px; padding:12px 0; border-bottom:1px solid rgba(30,26,20,0.08); }
  .curso-row:last-child{ border-bottom:none; }
  .curso-row b{ display:block; font-size:14px; }
  .curso-row span{ font-size:12px; color:#574E3F; }
  button, .dlbtn{ background:#1E1A14; color:#fff; border:none; padding:10px 16px; border-radius:100px; font-size:13px; font-weight:700; cursor:pointer; white-space:nowrap; }
  button:disabled{ opacity:.5; cursor:not-allowed; }
  button.secondary{ background:transparent; color:#1E1A14; border:1px solid rgba(30,26,20,0.25); }
  #log{ margin-top:20px; background:#FFFDF7; border:1px solid rgba(30,26,20,0.1); border-radius:14px; padding:16px 20px; font-family:ui-monospace,monospace; font-size:12.5px; white-space:pre-wrap; max-height:360px; overflow-y:auto; }
  .gate{ padding:16px 20px; background:#fff3f0; border:1px solid #D9754C; border-radius:14px; color:#B4462B; font-size:13.5px; }
  code{ background:rgba(30,26,20,0.06); padding:1px 6px; border-radius:6px; }
</style>
</head>
<body>
  <h1>Migração de cursos (sem Storage)</h1>
  <p>
    Ferramenta de uso único. Como o Storage / plano Blaze não vão ser ativados por enquanto,
    o fluxo aqui é: <b>1)</b> você baixa a capa e a apostila (PDF) dos 2 cursos que hoje estão fixos
    no código do <code>home.html</code>, <b>2)</b> sobe esses arquivos manualmente na pasta
    <code>assets/</code> do seu repositório GitHub (do mesmo jeito que já faz pelo <code>admin.html</code>),
    e <b>3)</b> esta ferramenta cria os documentos na coleção <code>cursos</code> do Firestore já com o
    schema real usado pelo admin — com <code>CapaURL</code> e <code>Link</code> em branco, prontos pra você colar o link do GitHub depois.
  </p>
  <p>
    Regra do Firestore pra leitura de <code>cursos</code>: já está publicada (<code>allow read: if request.auth != null</code>), não precisa mexer.
    Regra de Storage: não é necessária, já que o Storage não vai ser usado agora.
  </p>

  <div class="step">
    <h2>Passo 1 — Baixar os arquivos</h2>
    <p style="margin-top:-6px;">Clique em cada botão pra salvar o arquivo no seu computador. Depois é só subir esses arquivos na pasta <code>assets/</code> do repositório, do jeito que você já faz.</p>
    <div id="downloadList"></div>
  </div>

  <div class="step">
    <h2>Passo 2 — Criar os documentos no Firestore</h2>
    <p style="margin-top:-6px;">
      Cria os 2 cursos na coleção <code>cursos</code> com <code>Status: "rascunho"</code> (não aparecem pros colaboradores ainda) e <code>CapaURL</code> vazio.
      Depois de subir os arquivos no GitHub, abra o <code>admin.html</code>, edite cada curso colando o link do GitHub em <code>CapaURL</code>
      (e em <code>Link</code>, no caso da apostila em PDF), confira os outros campos e mude o <code>Status</code> pra <code>"publicado"</code> quando estiver pronto.
    </p>
    <div id="gate" class="gate" style="display:none;"></div>
    <button id="btnMigrar" style="display:none;" onclick="migrar()">Criar documentos no Firestore</button>
    <div id="log"></div>
  </div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
  import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";
  import { getFirestore, doc, getDoc, addDoc, collection, getDocs } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

  // mesmo firebaseConfig real do projeto Cabana School (home.html / index.html)
  const firebaseConfig = {
    apiKey: "AIzaSyALJzDqdBpic88-0CnKXCBUpvMhfilskkg",
    authDomain: "cabana-school-c.firebaseapp.com",
    projectId: "cabana-school-c",
    storageBucket: "cabana-school-c.firebasestorage.app",
    messagingSenderId: "299980031099",
    appId: "1:299980031099:web:afcd83482c194d35400ede"
  };

  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const db = getFirestore(app);

  const logEl = document.getElementById('log');
  function log(msg){
    logEl.textContent += msg + '\n';
    logEl.scrollTop = logEl.scrollHeight;
    console.log(msg);
  }

  function slugify(str){
    return str.toString().normalize('NFD').replace(/[\u0300-\u036f]/g,'')
      .toLowerCase().trim()
      .replace(/[^a-z0-9]+/g,'-')
      .replace(/(^-|-$)/g,'');
  }

  function dataURLtoBlob(dataUrl){
    const [meta, base64] = dataUrl.split(',');
    const mime = meta.match(/data:(.*?);base64/)[1];
    const bin = atob(base64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return new Blob([bytes], { type: mime });
  }

  function baixarArquivo(dataUrl, filename){
    const blob = dataURLtoBlob(dataUrl);
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 4000);
  }
  window.baixarArquivo = baixarArquivo;

const CURSOS_SEED = [
  {
    titulo: "De Olho no Padrão",
    descricao: "Treinamento oficial sobre padrões operacionais e atenção aos detalhes no dia a dia da loja.",
    categoria: "Operação",
    emoji: "👨‍🍳",
    cor: "#4F9C40",
    duracao: "18 min",
    status: "destaque",
    tipo: "canva",
    capa: "data:image/png;base64,",
    link: "https://cabanatreinamentos.my.canva.site/curso-digital-de-olho-no-padr-o",
    progresso: 60,
    concluido: false,
    real: true,
    objetivo1: "Reconhecer os pontos críticos do padrão Cabana em batata e hambúrguer.",
    objetivo2: "Reduzir reclamações de CX ligadas a padrão de produto.",
    publico: "Equipe operacional"
  },
  {
    titulo: "Segurança Alimentar na Cozinha",
    descricao: "Boas práticas de higiene e manipulação segura de alimentos na cozinha Cabana.",
    categoria: "Operação",
    emoji: "🍟",
    cor: "#D9754C",
    duracao: "10 min",
    status: "",
    tipo: "pdf",
    capa: "data:image/png;base64,",
    link: "data:application/pdf;base64,",
    progresso: 0,
    concluido: false,
    real: true,
    objetivo1: "Aplicar boas práticas de higienização de utensílios e superfícies.",
    objetivo2: "Reconhecer temperaturas seguras de armazenamento e preparo.",
    publico: "Equipe de cozinha"
  }
];


  // ===== monta o Passo 1 (botões de download) =====
  const downloadListEl = document.getElementById('downloadList');
  CURSOS_SEED.forEach((c) => {
    const slug = slugify(c.titulo);
    const row = document.createElement('div');
    row.className = 'curso-row';

    const botoes = [];
    if (c.capa && c.capa.indexOf('data:') === 0){
      botoes.push(`<button onclick="baixarArquivo(CURSOS_SEED[${CURSOS_SEED.indexOf(c)}].capa, '${slug}-capa.png')">Baixar capa (.png)</button>`);
    }
    if (c.link && c.link.indexOf('data:application/pdf') === 0){
      botoes.push(`<button class="secondary" onclick="baixarArquivo(CURSOS_SEED[${CURSOS_SEED.indexOf(c)}].link, '${slug}-apostila.pdf')">Baixar apostila (.pdf)</button>`);
    }

    row.innerHTML = `
      <div>
        <b>${c.titulo}</b>
        <span>${c.link && c.link.indexOf('data:') !== 0 ? 'Link externo já é uma URL real, não precisa baixar nada pra ele.' : ''}</span>
      </div>
      <div style="display:flex; gap:8px;">${botoes.join('')}</div>
    `;
    downloadListEl.appendChild(row);
  });

  // ===== Passo 2 (criação dos documentos) =====
  window.migrar = async function(){
    const btn = document.getElementById('btnMigrar');
    btn.disabled = true;
    log('Verificando cursos já existentes...');

    let titulosExistentes = new Set();
    try {
      const existentes = await getDocs(collection(db, 'cursos'));
      existentes.forEach(d => titulosExistentes.add((d.data().Titulo || '').trim()));
    } catch (err) {
      log('Erro ao checar cursos existentes: ' + err.message);
    }

    for (const c of CURSOS_SEED){
      if (titulosExistentes.has(c.titulo.trim())){
        log('AVISO: já existe um curso chamado "' + c.titulo + '" no Firestore, pulando pra não duplicar.');
        continue;
      }

      // link: se já era uma URL real (não base64), preserva; se era base64 (apostila em PDF), deixa em branco pra você preencher com o link do GitHub
      const linkFinal = (c.link && c.link.indexOf('data:') === 0) ? '' : (c.link || '');

      // TipoConteudo no admin.html só existe como canva/video/audio/link (não tem "pdf") —
      // a apostila em PDF vira um link externo, como as outras opções que não são vídeo/áudio/canva
      const tipoFinal = c.tipo === 'pdf' ? 'link' : c.tipo;

      try {
        const novoDoc = await addDoc(collection(db, 'cursos'), {
          Titulo: c.titulo,
          Descricao: c.descricao,
          Categoria: c.categoria,
          Duracao: c.duracao,
          TipoConteudo: tipoFinal,
          Link: linkFinal,
          CapaURL: '',
          Status: 'rascunho',
          Selo: c.status === 'destaque' ? 'destaque' : 'nenhum',
          CargosEspecificos: false,
          Cargos: [],
          CertificadoModeloURL: '',
          Objetivo1: c.objetivo1 || '',
          Objetivo2: c.objetivo2 || '',
          CriadoEm: new Date().toISOString()
        });
        log('"' + c.titulo + '" criado em cursos/' + novoDoc.id + ' (Status: rascunho, CapaURL/Link em branco pra você preencher).');
      } catch (err) {
        log('ERRO ao criar "' + c.titulo + '": ' + err.message);
      }
    }

    log('Pronto. Agora: suba os arquivos baixados no passo 1 pro GitHub, edite os 2 cursos no admin.html colando os links, e mude Status pra "publicado" quando revisar.');
    btn.textContent = 'Concluído';
  };

  // só libera quem estiver logado como Admin
  onAuthStateChanged(auth, async (user) => {
    const gate = document.getElementById('gate');
    const btn = document.getElementById('btnMigrar');
    if (!user){
      gate.style.display = 'block';
      gate.textContent = 'Você precisa estar logada na Cabana School pra usar esta ferramenta. Abra o login (index.html) primeiro, depois volte aqui.';
      return;
    }
    const cpf = (user.email || '').split('@')[0];
    let nivel = '';
    try {
      const snap = await getDoc(doc(db, 'colaboradores', cpf));
      if (snap.exists()) nivel = snap.data().Nivel || '';
    } catch (err) {
      log('Erro ao checar permissão: ' + err.message);
    }
    if (nivel !== 'Admin'){
      gate.style.display = 'block';
      gate.textContent = 'Acesso restrito ao Admin. Faça login com uma conta de nível Admin pra usar esta ferramenta.';
      return;
    }
    gate.style.display = 'none';
    btn.style.display = 'inline-block';
    log('Logada como Admin (' + cpf + '). Pronta pra criar os documentos.');
  });
</script>
</body>
</html>
